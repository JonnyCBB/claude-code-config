{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Write",
      "Edit",
      "Read",
      "Grep",
      "Glob",
      "WebSearch",
      "WebFetch",
      "Search(pattern:*)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(which *)",
      "Bash(pwd)",
      "Bash(echo *)",
      "Bash(env)",
      "Bash(printenv *)",
      "Bash(lsof *)",
      "Bash(awk *)",
      "Bash(test -f *)",
      "Bash(realpath *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git fetch *)",
      "Bash(git rev-parse *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git remote *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh repo view *)",
      "Bash(gh api *)",
      "Bash(gh gist create *)",
      "Bash(gsutil ls *)",
      "Bash(bq query *)",
      "Bash(bq ls *)",
      "Bash(curl *)",
      "Bash(mkdir *)",
      "Bash(pytest *)",
      "Bash(tox -e *)",
      "Bash(uv run isort *)",
      "Bash(uv run black *)",
      "Bash(uv run ruff *)",
      "Bash(python3 -c *)",
      "Bash(uv run pytest *)"
    ],
    "deny": [],
    "ask": []
  },
  "model": "opus[1m]",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh 'Claude Code is waiting for your input'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/auto-format.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/security-block.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'CMD=$(jq -r \".tool_input.command\" < /dev/stdin); if echo \"$CMD\" | grep -q \"git commit\"; then echo \"{\\\"additionalContext\\\": \\\"Before committing, ensure tests pass and code is formatted.\\\"}\"; fi'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-context.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/sync-plugins.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh 'Claude Code has stopped'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": false,
    "context7@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "crit@crit": true,
    "feature-dev@claude-plugins-official": true,
    "eng-utils@jbb-claude-code-plugins": true,
    "jiffy-toolkit@jbb-claude-code-plugins": true,
    "jbb-feature-dev@jbb-claude-code-plugins": true
  },
  "extraKnownMarketplaces": {
    "crit": {
      "source": {
        "source": "github",
        "repo": "tomasz-tomczyk/crit"
      }
    },
    "jbb-claude-code-plugins": {
      "source": {
        "source": "git",
        "url": "https://github.com/JonnyCBB/claude-code-config.git"
      },
      "autoUpdate": true
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true
}
